# Database
DB_PASSWORD=dev_password_123

# JWT
JWT_SECRET=this-is-a-256-bit-secret-key-for-development-only-change-in-prod

# Stripe (get test keys from https://dashboard.stripe.com/test/apikeys)
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_secret_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_key_here

# Mail (use Mailtrap for testing: https://mailtrap.io)
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=your_mailtrap_username
MAIL_PASSWORD=your_mailtrap_password

# Oracle Cloud (for deployment)
ORACLE_VM_IP=your_vm_ip
ORACLE_SSH_PRIVATE_KEY=path/to/key
